{
  "expo": {
    "name": "FX Pro 2026",
    "slug": "frontend",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fxpro",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan QR codes to send money instantly",
        "NSPhotoLibraryUsageDescription": "Pick a profile photo and save receipts",
        "NSPhotoLibraryAddUsageDescription": "Save your transaction receipts",
        "NSFaceIDUsageDescription": "Unlock your wallet with Face ID",
        "NSUserNotificationsUsageDescription": "Receive transaction alerts"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      [
        "expo-camera",
        { "cameraPermission": "Allow FX Pro to scan QR codes for payments" }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Allow FX Pro to use a profile photo from your gallery" }
      ],
      [
        "expo-local-authentication",
        { "faceIDPermission": "Allow FX Pro to use Face ID for secure unlock" }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00FFFF",
          "sounds": []
        }
      ]
    ],
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#00FFFF"
    },
    "experiments": { "typedRoutes": true }
  }
}
