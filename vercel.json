{
  "installCommand": "cd frontend && npx yarn@1.22.22 install --frozen-lockfile",
  "buildCommand": "cd frontend && npx yarn@1.22.22 build:web",
  "outputDirectory": "frontend/dist",
  "headers": [
    {
      "source": "/firebase-messaging-sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!_expo/|assets/|icons/|manifest.json|firebase-messaging-sw.js|browserconfig.xml|offline.html|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
