# FX Pro 2026 — Variables d'environnement Frontend
# Copiez ce fichier en `.env` (ou `.env.local`) puis remplissez les valeurs.

# URL du backend FastAPI (ex: https://api.fxpro2026.com)
# Laissez vide pour utiliser un proxy/host par defaut.
EXPO_PUBLIC_BACKEND_URL=

# Cle VAPID Firebase Cloud Messaging (FCM Web Push)
# Recuperez-la dans Firebase Console:
#   Console > Project Settings > Cloud Messaging > Web Push certificates
# Sans cette cle, les notifications PUSH du serveur ne fonctionneront pas
# sur navigateur/PWA (les notifications locales fonctionnent toujours).
EXPO_PUBLIC_FIREBASE_VAPID_KEY=

# Expo project id used by expo-notifications to create native push tokens.
# Set it in Codemagic if you use Expo push notifications.
EXPO_PUBLIC_EAS_PROJECT_ID=
