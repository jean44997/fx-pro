rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/fxpro_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/fxpro_users/$(request.auth.uid)).data.role == "admin";
    }

    match /fxpro_users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId)
        || isAdmin()
        || (signedIn()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["balances", "updated_at"]));
      allow delete: if isSelf(userId) || isAdmin();
    }

    match /fxpro_transactions/{txnId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow update, delete: if false;
    }

    match /fxpro_notifications/{notifId} {
      allow read, update, delete: if signedIn() && resource.data.user_id == request.auth.uid;
      allow create: if signedIn();
    }

    match /fxpro_alerts/{alertId} {
      allow read, update, delete: if signedIn() && resource.data.user_id == request.auth.uid;
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
    }

    match /fxpro_vaults/{vaultId} {
      allow read, update, delete: if signedIn() && resource.data.user_id == request.auth.uid;
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
    }

    match /fxpro_push_tokens/{userId} {
      allow read, write: if isSelf(userId) || isAdmin();
    }
  }
}
